# NetSite developer compose stack — environment overrides.
#
# Copy this file to ./.env (kept out of git via .gitignore) and edit
# values you want to override. Every variable is optional; the
# docker-compose.yml ships sensible defaults for local development.
#
# Why a sample env file rather than committing a .env: developers can
# bind-mount a different Postgres password locally without committing a
# password change to git. The sample documents the contract.

# Postgres
NETSITE_PG_DB=netsite
NETSITE_PG_USER=netsite
NETSITE_PG_PASSWORD=netsite
NETSITE_PG_PORT=5432

# ClickHouse
NETSITE_CH_DB=netsite
NETSITE_CH_USER=netsite
NETSITE_CH_PASSWORD=netsite
NETSITE_CH_NATIVE_PORT=9000
NETSITE_CH_HTTP_PORT=8123

# NATS
NETSITE_NATS_PORT=4222
NETSITE_NATS_MGMT_PORT=8222

# OpenTelemetry collector
NETSITE_OTLP_GRPC_PORT=4317
NETSITE_OTLP_HTTP_PORT=4318
NETSITE_OTEL_PROM_PORT=9464

# Prometheus
NETSITE_PROM_PORT=9090

# Grafana
NETSITE_GRAFANA_USER=admin
NETSITE_GRAFANA_PASSWORD=admin
NETSITE_GRAFANA_PORT=3000
